<!DOCTYPE html>
<html>
  <head>
    <title>LISTA USERA</title>
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        background-color: #0f0f0f;
        color: #e0e0e0;
        font-family: 'Segoe UI', sans-serif;
        padding: 40px;
      }

      h1 {
        font-size: 28px;
        margin-bottom: 10px;
        color: #ffffff;
      }

      h2 {
        font-size: 18px;
        color: #888;
        margin-bottom: 30px;
      }

      .search-bar {
        margin-bottom: 25px;
      }

      .search-bar input {
        background-color: #1a1a1a;
        border: 1px solid #2a2a2a;
        color: #fff;
        padding: 12px 18px;
        border-radius: 8px;
        font-size: 14px;
        width: 300px;
        outline: none;
        transition: border-color 0.2s;
      }

      .search-bar input:focus {
        border-color: #555;
      }

      .search-bar button {
        background-color: #2a2a2a;
        color: #ccc;
        border: none;
        padding: 12px 20px;
        border-radius: 8px;
        font-size: 14px;
        cursor: pointer;
        margin-left: 8px;
      }

      .search-bar button:hover {
        background-color: #333;
        color: #fff;
      }

      table {
        width: 100%;
        border-collapse: collapse;
        background-color: #1a1a1a;
        border-radius: 10px;
        overflow: hidden;
      }

      thead {
        background-color: #2a2a2a;
      }

      th {
        padding: 15px 20px;
        text-align: left;
        font-size: 13px;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: #888;
      }

      td {
        padding: 15px 20px;
        border-bottom: 1px solid #2a2a2a;
        font-size: 15px;
      }

      tr:last-child td {
        border-bottom: none;
      }

      tr:hover td {
        background-color: #222;
      }

      .btn-izbrisi {
        background-color: #c0392b;
        color: white;
        border: none;
        padding: 7px 16px;
        border-radius: 6px;
        cursor: pointer;
        font-size: 13px;
      }

      .btn-izbrisi:hover {
        background-color: #e74c3c;
      }
    </style>
  </head>
  <body>
    <h1>DOBRODOŠAO</h1>
    <h2>LISTA USERA NA BAZI:</h2>

    <div class="search-bar">
      <form action="/admin-dashboard/useri" method="GET">
        <input type="text" name="pretrazi" placeholder="Pretraži po imenu ili emailu..."/>
        <button type="submit">TRAŽI</button>
      </form>
    </div>

    <table>
      <thead>
        <tr>
          <th>#</th>
          <th>Ime</th>
          <th>Email</th>
          <th>Akcija</th>
        </tr>
      </thead>
      <tbody>
        <% korisnici.forEach((korisnik, index) => { %>
        <tr>
          <td><%= index + 1 %></td>
          <td><%= korisnik.ime %></td>
          <td><%= korisnik.email %></td>
          <td>
            <form action="/admin-dashboard" method="POST">
              <input type="hidden" name="akcija" value="brisi">
              <input type="hidden" name="id" value="<%= korisnik.id %>">
              <button class="btn-izbrisi" type="submit">IZBRIŠI</button>
            </form>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </body>
</html>