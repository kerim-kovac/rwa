<!DOCTYPE html>
<html>
  <head>
    <title>DASHBOARD</title>
    <style>
      @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600&family=Inter:wght@300;400;500&display=swap');

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        background-color: #0f0f0f;
        color: #e0e0e0;
        font-family: 'Inter', sans-serif;
        display: flex;
        min-height: 100vh;
      }

      .sidebar {
        width: 260px;
        background-color: #1a1a1a;
        border-right: 1px solid #2a2a2a;
        display: flex;
        flex-direction: column;
        padding: 40px 0;
        position: fixed;
        height: 100vh;
      }

      .logo {
        font-family: 'Playfair Display', serif;
        font-size: 20px;
        color: #ffffff;
        padding: 0 30px;
        margin-bottom: 50px;
        letter-spacing: 1px;
      }

      .logo span {
        color: #c8a96e;
      }

      .nav-label {
        font-size: 11px;
        color: #555;
        text-transform: uppercase;
        letter-spacing: 2px;
        padding: 0 30px;
        margin-bottom: 12px;
      }

      .nav-item {
        width: 100%;
        background: none;
        border: none;
        color: #888;
        font-family: 'Inter', sans-serif;
        font-size: 14px;
        padding: 12px 30px;
        text-align: left;
        cursor: pointer;
        transition: all 0.2s;
        display: flex;
        align-items: center;
        gap: 12px;
      }

      .nav-item:hover {
        background-color: #222;
        color: #fff;
      }

      .nav-item.active {
        background-color: #222;
        color: #c8a96e;
        border-right: 2px solid #c8a96e;
      }

      .nav-icon {
        font-size: 16px;
      }

      .sidebar-bottom {
        margin-top: auto;
        border-top: 1px solid #2a2a2a;
        padding-top: 20px;
      }

      .btn-logout {
        width: 100%;
        background: none;
        border: none;
        color: #888;
        font-family: 'Inter', sans-serif;
        font-size: 14px;
        padding: 12px 30px;
        text-align: left;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 12px;
        transition: all 0.2s;
      }

      .btn-logout:hover {
        color: #e74c3c;
      }

      .main {
        margin-left: 260px;
        flex: 1;
        padding: 60px;
      }

      .topbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 50px;
      }

      .pozdrav h1 {
        font-family: 'Playfair Display', serif;
        font-size: 36px;
        color: #ffffff;
        margin-bottom: 8px;
      }

      .pozdrav p {
        font-size: 15px;
        color: #666;
        font-weight: 300;
      }

      .profile-box a img {
        width: 55px;
        height: 55px;
        border-radius: 50%;
        object-fit: cover;
        border: 2px solid #c8a96e;
        display: block;
      }

      .chat-wrap {
        max-width: 800px;
      }

      .chat-input {
        display: flex;
        gap: 12px;
        margin-bottom: 30px;
      }

      .chat-input input {
        flex: 1;
        background-color: #1a1a1a;
        border: 1px solid #2a2a2a;
        color: #fff;
        padding: 14px 18px;
        border-radius: 8px;
        font-size: 15px;
        font-family: 'Inter', sans-serif;
        outline: none;
        transition: border-color 0.2s;
      }

      .chat-input input:focus {
        border-color: #c8a96e;
      }

      .chat-input button {
        background-color: #c8a96e;
        color: #0f0f0f;
        border: none;
        padding: 14px 24px;
        border-radius: 8px;
        font-size: 14px;
        font-family: 'Inter', sans-serif;
        font-weight: 500;
        cursor: pointer;
        transition: background-color 0.2s;
      }

      .chat-input button:hover {
        background-color: #b8935a;
      }

      .chat-poruke {
        display: flex;
        flex-direction: column;
        gap: 12px;
      }

      .poruka {
        background-color: #1a1a1a;
        border: 1px solid #2a2a2a;
        border-radius: 10px;
        padding: 16px 20px;
        display: flex;
        flex-direction: column;
        gap: 8px;
        transition: border-color 0.2s;
      }

      .poruka:hover {
        border-color: #333;
      }

      .poruka-ime {
        font-size: 13px;
        color: #c8a96e;
        font-weight: 500;
      }

      .poruka-tekst {
        font-size: 15px;
        color: #e0e0e0;
      }

      .poruka-akcije {
        display: flex;
        gap: 10px;
        align-items: center;
      }

      .poruka-akcije button {
        background: none;
        border: 1px solid #2a2a2a;
        color: #888;
        padding: 5px 12px;
        border-radius: 6px;
        font-size: 12px;
        font-family: 'Inter', sans-serif;
        cursor: pointer;
        transition: all 0.2s;
      }

      .poruka-akcije button:hover {
        border-color: #c8a96e;
        color: #c8a96e;
      }

      .btn-obrisi {
        border-color: #c0392b !important;
        color: #c0392b !important;
      }

      .btn-obrisi:hover {
        background-color: #c0392b !important;
        color: #fff !important;
      }

      .likes-count {
        font-size: 13px;
        color: #666;
      }

      .poruka-datum {
        font-size: 11px;
        color: #444;
      }
    </style>
  </head>
  <body>

    <div class="sidebar">
      <div class="logo">TERRA<span>VISTA</span></div>

      <p class="nav-label">Navigacija</p>

      <form action="/dashboard" method="POST">
        <input type="hidden" name="akcija" value="informacije">
        <button class="nav-item" type="submit">
          <span class="nav-icon">👤</span> Profil
        </button>
      </form>
      <form action="/dashboard" method="POST">
        <input type="hidden" name="akcija" value="promjenasifre">
        <button class="nav-item" type="submit">
          <span class="nav-icon">🔒</span> Password Change
        </button>
      </form>
      <form action="/dashboard" method="POST">
        <input type="hidden" name="akcija" value="promjenausera">
        <button class="nav-item" type="submit">
          <span class="nav-icon">✏️</span> Username Change
        </button>
      </form>
      <form action="/dashboard" method="POST">
        <input type="hidden" name="akcija" value="promjenamaila">
        <button class="nav-item" type="submit">
          <span class="nav-icon">📧</span> Email Change
        </button>
      </form>

      <div class="sidebar-bottom">
        <form action="/dashboard" method="POST">
          <input type="hidden" name="akcija" value="logout">
          <button class="btn-logout" type="submit">
            <span class="nav-icon">🚪</span> Logout
          </button>
        </form>
      </div>
    </div>

    <div class="main">
      <div class="topbar">
        <div class="pozdrav">
          <h1>Dobrodošao, <%= korisnik.ime %> 👋</h1>
          <p>Lijepo je imati te nazad. Šta danas planiraš?</p>
        </div>
        <div class="profile-box">
          <% if(korisnik.slika){ %>
            <a href="/dashboard/informacije"><img src="/images/<%= korisnik.slika %>" alt="profilna slika"></a>
          <% } else { %>
            <a href="/dashboard/informacije"><img src="/images/default.jpg" alt="nema"></a>
          <% } %>
        </div>
      </div>

      <div class="chat-wrap">
        <div class="chat-input">
          <form action="/dashboard/chat" method="POST">
            <input type="text" name="poruka" placeholder="Napiši poruku..."/>
            <button type="submit">POŠALJI</button>
          </form>
        </div>

        <div class="chat-poruke">
          <% poruke.forEach(poruka => { %>
            <div class="poruka">
              <span class="poruka-ime"><%= poruka.ime %></span>
              <span class="poruka-tekst"><%= poruka.poruka %></span>
              <div class="poruka-akcije">
                <span class="likes-count">❤️ <%= poruka.likes %></span>
                <% if(korisnik.id != poruka.korisnik_id){ %>
                  <form action="/dashboard/like" method="POST">
                    <input type="hidden" name="id" value="<%= poruka.id %>">
                    <button type="submit">Lajkaj</button>
                  </form>
                <% } %>
                <% if(poruka.korisnik_id == korisnik.id){ %>
                  <form action="/dashboard/obrisi-chat" method="POST">
                    <input type="hidden" name="id" value="<%= poruka.id %>">
                    <button type="submit" class="btn-obrisi">Obriši</button>
                  </form>
                <% } %>
              </div>
              <span class="poruka-datum"><%= poruka.datum %></span>
            </div>
          <% }) %>
        </div>
      </div>
    </div>

  </body>
</html>