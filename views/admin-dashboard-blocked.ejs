<!DOCTYPE html>
<html>
  <head>
    <title>ADMIN PANEL</title>
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        background-color: #0f0f0f;
        color: #e0e0e0;
        font-family: 'Segoe UI', sans-serif;
        padding: 40px;
      }

      h1 {
        font-size: 30px;
        margin-bottom: 5px;
      }

      h2 {
        font-size: 16px;
        color: #888;
        margin-bottom: 30px;
      }

      table {
        width: 100%;
        border-collapse: collapse;
        background-color: #1a1a1a;
        border-radius: 12px;
        overflow: hidden;
      }

      thead {
        background-color: #2a2a2a;
      }

      th {
        padding: 15px;
        text-align: left;
        font-size: 12px;
        text-transform: uppercase;
        color: #888;
      }

      td {
        padding: 15px;
        border-bottom: 1px solid #2a2a2a;
      }

      tr:hover {
        background-color: #222;
      }

      /* STATUS BADGE */
      .status {
        padding: 5px 10px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: bold;
      }

      .active {
        background-color: #27ae60;
        color: white;
      }

      .blocked {
        background-color: #c0392b;
        color: white;
      }

      /* FORMA */
      form {
        display: flex;
        gap: 8px;
        align-items: center;
      }

      select,
      input[type="text"] {
        background-color: #0f0f0f;
        border: 1px solid #2a2a2a;
        color: #fff;
        padding: 6px 10px;
        border-radius: 6px;
        font-size: 13px;
        outline: none;
      }

      select {
        cursor: pointer;
      }

      input[type="text"] {
        width: 140px;
      }

      select:focus,
      input[type="text"]:focus {
        border-color: #555;
      }

      /* BUTTON */
      .btn {
        background: linear-gradient(135deg, #e74c3c, #c0392b);
        border: none;
        color: white;
        padding: 6px 14px;
        border-radius: 6px;
        cursor: pointer;
        font-size: 13px;
        transition: 0.2s;
      }

      .btn:hover {
        opacity: 0.85;
      }
    </style>
  </head>

  <body>
    <h1>Admin Panel</h1>
    <h2>Upravljanje korisnicima</h2>

    <table>
      <thead>
        <tr>
          <th>#</th>
          <th>Ime</th>
          <th>Email</th>
          <th>Status</th>
          <th>Akcija</th>
        </tr>
      </thead>

      <tbody>
        <% korisnici.forEach((korisnik, index) => { %>
        <tr>
          <td><%= index + 1 %></td>
          <td><%= korisnik.ime %></td>
          <td><%= korisnik.email %></td>

          <td>
            <% if(korisnik.blokiran == 1){ %>
              <span class="status active">Aktivan</span>
            <% } else { %>
              <span class="status blocked">Blokiran</span>
            <% } %>
          </td>

          <td>
            <form action="/admin-dashboard" method="POST">
              <input type="hidden" name="akcija" value="blokiraj">
              <input type="hidden" name="id" value="<%= korisnik.id %>">

              <select name="aktivnost">
                <option value="1">Aktivan</option>
                <option value="0">Blokiran</option>
              </select>

              <input type="text" name="razlog" placeholder="Razlog" />

              <button class="btn" type="submit">Sačuvaj</button>
            </form>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </body>
</html>